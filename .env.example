# ─── API Keys ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OLLAMA_HOST=http://host.docker.internal:11434  # or localhost:11434

# ─── App Settings ────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
TOKEN_EXP_MINUTES=600
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Frontend CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080

# ─── Database / Storage ──────────────────────────────────────────────────────
# Use Render persistent disk path if available, or local fallback
RENDER_DISK_PATH=./backend/data
CHROMA_DB_PATH=./backend/chroma_db

# ─── Billing / Monetization (optional for local) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Render deployment integration ───────────────────────────────────────────
RENDER_SERVICE_URL=https://nexus-backend.onrender.com
RENDER_API_KEY=render_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxx
