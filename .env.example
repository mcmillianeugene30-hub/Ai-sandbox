# ─── Backend (Render) ─────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Token expiration (minutes)
TOKEN_EXP_MINUTES=600

# Your Vercel frontend URL (set in Render dashboard → Environment)
FRONTEND_URL=https://your-nexus.vercel.app

# Render disk mount path (auto-set by Render when disk is attached)
# RENDER_DISK_PATH=/opt/render/project/src/data

# Render deployment (for AutoDeployAgent)
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxx
RENDER_SERVICE_ID=srv-xxxxxxxx
RENDER_SERVICE_URL=https://nexus-backend.onrender.com

# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
# Set in Vercel dashboard → Project Settings → Environment Variables
VITE_API_URL=https://nexus-backend.onrender.com
