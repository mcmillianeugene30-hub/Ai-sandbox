# ─── Backend (Render) ─────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_secret
TOKEN_EXP_MINUTES=600
FRONTEND_URL=https://your-nexus.vercel.app

# LLM provider API keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Nexus OS / data paths
NEXUS_OS_PATH=/opt/render/project/src/nexus-ai-os
RENDER_DISK_PATH=/opt/render/project/src/backend/data
CHROMA_DB_PATH=/opt/render/project/src/backend/chroma_db

# Render deployment integration
RENDER_SERVICE_URL=https://nexus-backend.onrender.com
RENDER_API_KEY=render_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxx

# ─── Frontend (Vercel/static) ──────────────────────────────────────────────────
# config.js should expose window.NEXUS_API with the /api/v1 suffix, for example:
# window.NEXUS_API = 'https://nexus-backend.onrender.com/api/v1';
VITE_API_URL=https://nexus-backend.onrender.com/api/v1
